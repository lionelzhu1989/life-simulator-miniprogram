.header-card {
  margin-bottom: 20rpx;
}
.header-top {
  display: flex;
  justify-content: space-between;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}
.cash-row {
  display: flex;
  justify-content: space-between;
  color: #666;
  font-size: 26rpx;
}
.stats-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 20rpx;
}
.stat-item {
  width: calc(50% - 10rpx);
  text-align: center;
}
.stat-item .label {
  display: block;
  color: #666;
  font-size: 24rpx;
  margin-bottom: 8rpx;
}
.stat-item .value {
  font-size: 36rpx;
  font-weight: bold;
}
.entry-group {
  margin-bottom: 20rpx;
}
.entry-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  font-size: 28rpx;
}
.arrow {
  color: #999;
}
.ai-entry {
  background: linear-gradient(90deg, #3498db, #2ecc71);
  color: #fff;
  text-align: center;
  font-weight: bold;
  margin-bottom: 30rpx;
}
.next-btn {
  background: #3498db;
  color: #fff;
  margin-bottom: 20rpx;
}
.btn-row {
  display: flex;
  gap: 20rpx;
}
.half-btn {
  flex: 1;
  background: #ecf0f1;
  color: #2c3e50;
  font-size: 26rpx;
}
.half-btn.reset {
  color: #e74c3c;
}
.modal-text {
  display: block;
  margin-bottom: 30rpx;
  font-size: 28rpx;
  line-height: 1.6;
  text-align: center;
}
