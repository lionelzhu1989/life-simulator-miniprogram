page {
  background-color: #f5f6fa;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
  color: #2c3e50;
}
.container {
  padding: 24rpx;
  box-sizing: border-box;
}
.section-title {
  font-size: 30rpx;
  font-weight: bold;
  margin: 30rpx 0 20rpx;
  padding-left: 10rpx;
  border-left: 6rpx solid #3498db;
}
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}
.btn-group {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}
.modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}
.modal-content {
  background: #fff;
  width: 80%;
  padding: 40rpx;
  border-radius: 16rpx;
  box-sizing: border-box;
}
.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 30rpx;
}
